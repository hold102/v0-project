# Supabase project credentials (used by the runtime API)
# Dashboard -> Project Settings -> API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=your-service-role-key-here

# Supabase Postgres connection string (used only by scripts/migrate.js)
# Dashboard -> Project Settings -> Database -> Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Optional: server port (defaults to 5001 if unset)
PORT=5001
